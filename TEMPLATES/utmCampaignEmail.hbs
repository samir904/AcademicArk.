{{! utmCampaignEmail.hbs }}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{subject}}</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      background:#080808;
      font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,
                  Helvetica,Arial,sans-serif;
      color:#d4d4d4;
      -webkit-text-size-adjust:100%;
      padding:40px 16px 64px;
    }

    .wrapper { max-width:520px; margin:0 auto; }

    /* ── Card ── */
    .card {
      background:#111;
      border:1px solid #1f1f1f;
      border-radius:20px;
      overflow:hidden;
      box-shadow:0 0 0 1px #0a0a0a, 0 24px 48px rgba(0,0,0,.6);
    }

    /* ── Top accent ── */
    .accent-bar {
      height:3px;
      background:linear-gradient(90deg,#6366f1 0%,#8b5cf6 50%,#06b6d4 100%);
    }

    /* ── Inner padding ── */
    .body { padding:32px 36px 32px; }

    /* ── Pill ── */
    .subject-pill {
      display:inline-flex; align-items:center; gap:6px;
      padding:4px 12px;
      background:#1a1a1a; border:1px solid #2a2a2a;
      border-radius:999px;
      font-size:11px; font-weight:600;
      color:#6366f1; letter-spacing:.06em;
      text-transform:uppercase;
      margin-bottom:20px;
    }

    /* ── Greeting — clean, no background ── */
    .greeting {
      margin-bottom:24px;
    }
    .greeting-line {
      font-size:22px;
      font-weight:700;
      color:#ffffff;
      line-height:1.3;
    }

    /* ── Message ── */
    .message {
      font-size:14px; line-height:1.85;
      color:#9ca3af;
      white-space:pre-line;
      margin-bottom:28px;
    }

    /* ── Notice box ── */
    .notice {
      display:flex; gap:10px; padding:12px 16px;
      background:#161616; border:1px solid #2a2a2a;
      border-left:3px solid #6366f1; border-radius:10px;
      margin-bottom:24px;
    }
    .notice.warn    { border-left-color:#f59e0b; }
    .notice-icon    { font-size:16px; flex-shrink:0; }
    .notice-text    { font-size:13px; color:#9ca3af; line-height:1.6; }

    /* ── Divider ── */
    .divider { border:none; border-top:1px solid #1f1f1f; margin:24px 0; }

    /* ── CTA ── */
    .cta-wrap { text-align:center; padding:4px 0 8px; }
    .cta-btn  {
      display:inline-block; padding:14px 36px;
      background:#ffffff !important;
      color:#000000 !important;
      font-size:14px; font-weight:700;
      border-radius:12px;
      text-decoration:none !important;
      letter-spacing:.02em;
      border:none;
    }
    a.cta-btn, a.cta-btn:visited, a.cta-btn:hover {
      background:#ffffff !important;
      color:#000000 !important;
    }

    /* ── Signature ── */
    .signature       { margin-top:28px; padding-top:20px; border-top:1px solid #1a1a1a; }
    .sig-badge-wrap  { text-align:center; }
    .sig-badge {
      display:inline-flex; align-items:center; gap:8px;
      padding:6px 14px;
      background:#1a1a1a; border:1px solid #242424;
      border-radius:8px; font-size:12px; color:#555;
    }
    .sig-badge b { color:#6366f1; font-weight:600; }

    /* ── Footer ── */
    .footer {
      text-align:center; padding:28px 16px 0;
      font-size:11px; color:#3f3f3f; line-height:1.9;
    }
    .footer a { color:#4b5563; text-decoration:underline; }

    @media(max-width:480px){
      .body    { padding:24px 20px 24px; }
      .cta-btn { padding:13px 24px; font-size:13px; }
      .greeting-line { font-size:19px; }
    }
  </style>
</head>
<body>

  {{! Preheader }}
  <div style="display:none;max-height:0;overflow:hidden;color:#080808;font-size:1px">
    {{previewText}}&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;
  </div>

  <div class="wrapper">
    <div class="card">

      <div class="accent-bar"></div>

      <div class="body">

        {{! Audience pill }}
        <div class="subject-pill">✦ {{pillLabel}}</div>

        {{! Greeting — just a clean bold line, no box/avatar }}
        <div class="greeting">
          <div class="greeting-line">Hey {{recipientName}} 👋</div>
        </div>

        {{! Body }}
        <div class="message">{{message}}</div>

        {{! Optional notice }}
        {{#if noticeText}}
        <div class="notice{{#if noticeWarn}} warn{{/if}}">
          <div class="notice-icon">{{#if noticeWarn}}⚠️{{else}}✅{{/if}}</div>
          <div class="notice-text">{{{noticeText}}}</div>
        </div>
        {{/if}}

        {{! CTA }}
        {{#if ctaText}}
        <hr class="divider"/>
        <div class="cta-wrap">
          <a href="{{ctaLink}}" class="cta-btn"
            style="background:#ffffff;color:#000000;display:inline-block;
                   padding:14px 36px;border-radius:12px;font-weight:700;
                   font-size:14px;text-decoration:none;">
            {{ctaText}}
          </a>
        </div>
        {{/if}}

        {{! Signature }}
        <div class="signature">
          <div class="sig-badge-wrap">
            <div class="sig-badge">
              <b>AcademicArk</b>
            </div>
          </div>
        </div>

      </div>
    </div>

    {{! Footer }}
    <div class="footer">
      <p>You're receiving this because you have an account on AcademicArk.</p>
      <p style="margin-top:6px">
        <a href="{{unsubscribeLink}}">Unsubscribe</a> ·
        <a href="{{preferencesLink}}">Email Preferences</a>
      </p>
      <p style="margin-top:10px">© 2026 AcademicArk · Greater Noida, India</p>
    </div>
  </div>

  {{! Tracking pixel }}
  <img src="{{pixelUrl}}" width="1" height="1"
    style="display:none;width:1px;height:1px" alt=""/>

</body>
</html>